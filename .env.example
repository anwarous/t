# URL of the backend API (Spring Boot).
# Leave empty (or omit the file entirely) to use built-in demo mode,
# which stores users in localStorage — no server required.
VITE_API_BASE_URL=http://localhost:8080/api

# PostgreSQL connection (used by the Spring Boot backend).
# Set these environment variables before running the backend.
DB_HOST=your-db-host
DB_PORT=5432
DB_NAME=LearningDataBase
DB_USERNAME=postgres
DB_PASSWORD=yourpassword
