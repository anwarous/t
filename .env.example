# Frontend
# Base URL used by the Vite frontend to reach the backend API.
# In production image builds, this is baked into the static bundle.
VITE_API_BASE_URL=http://localhost:8081/api

# Base URL used by the Vite frontend to reach the algorithm compiler API.
# In production image builds, this is baked into the static bundle.
VITE_ALGO_COMPILER_URL=/algo-api

# Timeout for algorithm execution requests, in milliseconds.
VITE_ALGO_COMPILER_TIMEOUT_MS=60000

# Vite dev-server proxy target for /algo-api during local development.
# Use http://algo-compiler:5000 when frontend runs inside Docker Compose.
ALGO_COMPILER_PROXY_TARGET=http://localhost:5000

# CORS origin accepted by the algorithm compiler API.
# In dev override, this defaults to http://localhost:5174.
ALGO_ALLOWED_ORIGIN=http://localhost:5173

# Backend runtime
# Spring profile for container runtime.
SPRING_PROFILES_ACTIVE=prod

# Server port inside backend container.
SERVER_PORT=8081

# JWT settings for authentication.
# Use a long random secret in production (at least 32 characters).
APP_JWT_SECRET=learningplusplus-dev-jwt-secret-please-rotate-in-production-2026
APP_JWT_EXPIRATION_MS=604800000

# CORS allowed origins (comma-separated list).
APP_CORS_ALLOWED_ORIGINS=http://localhost:5173

# LLM mentor (OpenAI-compatible endpoint)
# Examples:
# - OpenAI: APP_LLM_BASE_URL=https://api.openai.com/v1
# - OpenRouter: APP_LLM_BASE_URL=https://openrouter.ai/api/v1
APP_LLM_BASE_URL=https://openrouter.ai/api/v1
APP_LLM_API_KEY=
APP_LLM_MODEL=nvidia/nemotron-3-super-120b-a12b:free
APP_LLM_TEMPERATURE=0.3
APP_LLM_MAX_TOKENS=450
APP_LLM_SYSTEM_PROMPT=You are Learning++ Mentor, an algorithm tutor. Explain clearly, give hints before full solutions, and keep answers concise and practical.

# PostgreSQL database settings.
DB_HOST=postgres
DB_PORT=5432
DB_NAME=LearningDataBase
DB_USERNAME=anwer
DB_PASSWORD=change-me

# Optional full JDBC override.
# If set, backend uses this directly instead of DB_HOST/DB_PORT/DB_NAME.
SPRING_DATASOURCE_URL=

# Optional datasource credentials override.
# If left empty, backend uses DB_USERNAME/DB_PASSWORD values.
SPRING_DATASOURCE_USERNAME=
SPRING_DATASOURCE_PASSWORD=
